# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
# Add your ngrok host (e.g. abc123.ngrok-free.app) when tunneling webhooks to localhost.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,testserver,.ngrok-free.app,.ngrok.io

# Local dev (no Docker): leave empty for SQLite, or point at Postgres on localhost.
# Example: postgresql://clinic_crm:password@127.0.0.1:5432/clinic_crm
DATABASE_URL=

# Docker Compose — shared by `db` (Postgres) and used to build `web`’s DATABASE_URL.
# Copy this file to `.env` before `docker compose up`. Keep passwords URL-safe (@, :, /, #
# in `POSTGRES_PASSWORD` break URLs unless percent-encoded).
#
# If you change POSTGRES_USER / POSTGRES_DB after the DB volume was created once, Postgres
# ignores the new values and your app/healthcheck will fail. Remove the volume and
# `docker compose up` again (data loss) or set these back to the original values.
POSTGRES_USER=clinic_crm
POSTGRES_PASSWORD=clinic_crm_secret_change_me
POSTGRES_DB=clinic_crm

# Serper.dev — Google Maps search
SERPER_API_KEY=

# Reserved for future AI features (not used by the app today).
GEMINI_API_KEY=

# WhatsApp — Meta Cloud API
# Primary line after Coex onboarding (e.g. +60126336429 on Business App + Cloud API).
# System User permanent token from Meta Business Manager (OAuth 190 = expired or wrong token).
WHATSAPP_ACCESS_TOKEN=
# Phone Number ID from WhatsApp Manager for the Coex number — not the display phone number.
WHATSAPP_PHONE_NUMBER_ID=
# Optional. If unset, resolved from the phone number ID via Graph API.
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_GRAPH_API_VERSION=v20.0
# Outbound template is hardcoded to ``just_to_say_hi`` with language code ``en`` (not en_US).
WHATSAPP_CAMPAIGN_TIMEZONE=Asia/Kuala_Lumpur
# Meta App Secret — required for inbound/echo webhooks in production (POST signature).
WHATSAPP_APP_SECRET=
# Must match Meta App → WhatsApp → Configuration → Webhook → Verify token.
WHATSAPP_WEBHOOK_VERIFY_TOKEN=CLINIC_CRM_WEBHOOK_73R469Mf
# Webhook callback (HTTPS): https://YOUR_PUBLIC_HOST/webhook/whatsapp/
# Subscribe WABA fields: messages, smb_message_echoes (Coex phone replies); history optional.
# Production HTTPS forms (Railway): set to https://YOUR_APP.up.railway.app
CSRF_TRUSTED_ORIGINS=https://YOUR_APP.up.railway.app
