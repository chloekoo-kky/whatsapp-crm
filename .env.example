# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
# Add tunnel hosts when testing webhooks locally (Cloudflare, ngrok).
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,testserver,.trycloudflare.com,.ngrok-free.app,.ngrok.io

# Local dev (no Docker): leave empty for SQLite, or point at Postgres on localhost.
DATABASE_URL=

# Docker Compose — shared by `db` and used to build `web`’s DATABASE_URL.
POSTGRES_USER=clinic_crm
POSTGRES_PASSWORD=clinic_crm_secret_change_me
POSTGRES_DB=clinic_crm

# Serper.dev — Google Maps search
SERPER_API_KEY=

# Reserved for future AI features.
GEMINI_API_KEY=

# --- WhatsApp via YCloud BSP (https://api.ycloud.com/v2) ---
# API key from YCloud Console → Developers → API Keys.
YCLOUD_API_KEY=
# Business sender in E.164 (your Coex line), e.g. +60126336529 — NOT a Meta Phone Number ID.
WHATSAPP_FROM_NUMBER=
# Optional override. If wrong, the app resolves WABA from WHATSAPP_FROM_NUMBER via YCloud API.
YCLOUD_WABA_ID=
# Webhook signing secret returned when you create a webhook endpoint in YCloud.
YCLOUD_WEBHOOK_SECRET=
WHATSAPP_CAMPAIGN_TIMEZONE=Asia/Kuala_Lumpur

# Webhook callback (HTTPS): https://YOUR_PUBLIC_HOST/whatsapp/webhook/
# Subscribe in YCloud to: whatsapp.inbound_message.received,
# whatsapp.smb.message.echoes (Coex phone replies), whatsapp.message.updated (optional)
# Production: set CSRF_TRUSTED_ORIGINS to your public app URL.
CSRF_TRUSTED_ORIGINS=https://YOUR_APP.up.railway.app

# --- Legacy Meta direct Cloud API (optional; webhooks only if still registered with Meta) ---
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_GRAPH_API_VERSION=v20.0
WHATSAPP_APP_SECRET=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=CLINIC_CRM_WEBHOOK_73R469Mf
